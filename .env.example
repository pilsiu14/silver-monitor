# Skopiuj ten plik jako .env.local i wpisz prawdziwe wartości
# .env.local jest w .gitignore - nigdy nie wrzucaj kluczy do git!

# Supabase (z dashboard.supabase.com → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://twoj-projekt.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx...
SUPABASE_SERVICE_ROLE_KEY=eyJxxx...

# Sekret dla cron joba (wygeneruj losowy ciąg)
CRON_SECRET=losowy-ciag-32-znakow

# OPCJONALNE: Telegram bot dla alertów
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
